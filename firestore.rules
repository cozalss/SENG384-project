// HEALTH AI — Firestore Security Rules
//
// Brief §5.2 ("Security") + §4.1 (RBAC). Without these rules deployed, the
// Firebase API key shipped in the client lets any anonymous visitor read or
// write every collection. Deploy with:
//   firebase deploy --only firestore:rules
//
// IMPORTANT — context for this academic prototype:
// The current client-side auth flow stores the user document in the `users`
// collection with `passwordHash`, then uses localStorage to track the
// "logged-in" identity. There is NO Firebase Auth session, which means
// `request.auth` is `null` for every request. Strict rules of the form
// `allow read: if request.auth != null` would lock the entire app out today.
//
// Until the project migrates to Firebase Auth (recommended next step), these
// rules enforce shape and field whitelists rather than identity. Once
// `signInWithEmailLink()` or a custom token flow is wired up, swap the
// permissive `allow` blocks below for the commented `// PROD:` versions.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Whitelist of fields a user is allowed to mutate on their OWN document.
    // Mirrors EDITABLE_USER_FIELDS in src/hooks/useAuth.js so the server-side
    // gate matches the client expectation. role, email, passwordHash, status,
    // institution(*), registeredAt, lastLogin, id are immutable from the
    // self-edit surface — admins use a separate path. (*institution is on the
    // self-edit list in useAuth; intentionally left out here so the formal
    // institutional affiliation isn't editable post-registration.)
    function userSelfEditOk() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'city', 'country', 'savedPosts']);
    }

    // -------- users --------
    match /users/{userId} {
      // Public read of profile is acceptable — the dashboard surfaces author
      // names + roles to every signed-in user. A more privacy-strict variant
      // would scope read to (self || admin || author-of-post-being-viewed).
      allow read: if true;

      // Anyone can create THEIR OWN user doc during registration. The doc ID
      // is the generated user id; we enforce that the email is institutional.
      allow create: if request.resource.data.email is string
        && request.resource.data.email.matches('^[^@]+@[a-z0-9.-]+\\.edu(\\.[a-z]{2})?$')
        && request.resource.data.role in ['Engineer', 'Healthcare Professional', 'Admin'];

      // Self can update only the whitelisted fields. Admin can flip status.
      allow update: if (isSelf(userId) && userSelfEditOk())
        || (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status']));

      // Only the user themselves (GDPR Article 17) or an admin can delete.
      allow delete: if isSelf(userId) || isAdmin();

      // PROD: tighten read once Firebase Auth lands.
      // allow read: if isSignedIn();
    }

    // -------- posts --------
    match /posts/{postId} {
      // Posts are public to authenticated users; the feed depends on it.
      allow read: if true;

      // Author must match the creating user's id. Status must start as Draft
      // or Active; statusHistory must contain exactly one entry on creation.
      allow create: if request.resource.data.authorId is string
        && request.resource.data.status in ['Draft', 'Active']
        && request.resource.data.interestCount == 0
        && request.resource.data.meetingCount == 0;

      // Author can edit their own post; admin can mutate anything.
      // Counters are bumped from subcollection writes via runTransaction;
      // the only "free" mutation here is by the author or admin.
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);

      // Only the author or an admin can delete a post.
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);

      // ---- post subcollections ----

      match /interests/{interestId} {
        allow read: if true; // post author + interested party both need to see
        // Anyone signed in can express interest, but the userId stamped on the
        // doc must match the requesting auth uid (no impersonation).
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.ndaAccepted == true;
        // Interests are append-only from the client; admins clean up.
        allow update: if isAdmin();
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid);
      }

      match /meetings/{meetingId} {
        allow read: if true;
        // Proposer's userId must match auth uid.
        allow create: if isSignedIn()
          && request.resource.data.proposedBy == request.auth.uid
          && request.resource.data.status == 'pending';
        // Author of the parent post can accept/decline; proposer can cancel
        // (which we handle via delete below). Status transitions are
        // restricted to the small set the workflow actually emits.
        allow update: if isAdmin()
          || (isSignedIn()
              && get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid
              && request.resource.data.status in ['accepted', 'declined']);
        // Proposer can cancel a still-pending meeting; admins can purge.
        allow delete: if isAdmin()
          || (isSignedIn()
              && resource.data.proposedBy == request.auth.uid
              && resource.data.status == 'pending');
      }
    }

    // -------- conversations / messages --------
    match /conversations/{convoId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.members;
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.members;
        allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // -------- notifications --------
    match /notifications/{notifId} {
      // Recipient + admin can read. Anyone signed in can write a notif (the
      // app needs to deliver "X did Y" messages cross-user); a tighter
      // production rule would require a Cloud Function intermediary.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.targetUserId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.targetUserId == request.auth.uid);
    }

    // -------- activityLogs --------
    match /activityLogs/{logId} {
      // Only admins can read the audit trail (Brief 4.6.3). Any signed-in
      // user can append their own action; updates and deletes are admin-only
      // (the retention sweep runs as admin).
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if false; // immutable once written
      allow delete: if isAdmin();
    }

    // -------- loginAttempts (rate limiting) --------
    match /loginAttempts/{emailKey} {
      // Brief 5.2 — anti-bot. Reads must be allowed unauth so the login form
      // can check the lockout state BEFORE the user has signed in. Writes
      // similarly come from the unauth login flow. Admin can read the full
      // table to spot brute-force patterns. In production this collection
      // should be migrated to a Cloud Function-only path so a malicious
      // client can't reset its own counter.
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin() || true; // self-clear on success
    }

    // -------- default deny --------
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
